{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ElMasriaDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_KEY_MIN_32_CHARS_LONG!!",
    "Issuer": "ElMasria.API",
    "Audience": "ElMasria.Client",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "RedisSettings": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ElMasria_"
  },
  "PaymobSettings": {
    "ApiKey": "",
    "HmacSecret": "",
    "IframeId": "",
    "IframeBaseUrl": "https://accept.paymob.com/api/acceptance/iframes",
    "VodafoneCashIntegrationId": "",
    "OrangeCashIntegrationId": "",
    "EtisalatCashIntegrationId": "",
    "FawryIntegrationId": "",
    "CardIntegrationId": ""
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@elmasria.com",
    "FromName": "متجر المصرية"
  },
  "ShippingSettings": {
    "FreeShippingThreshold": 500.00,
    "DefaultRateEgp": 35.00,
    "CairoRateEgp": 25.00,
    "GizaRateEgp": 25.00
  },
  "ImageSettings": {
    "UploadPath": "uploads/products",
    "MaxFileSizeMb": 5,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "ThumbnailSizes": [ 300, 600, 1200 ],
    "BaseUrl": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
