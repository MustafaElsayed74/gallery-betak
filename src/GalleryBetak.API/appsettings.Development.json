{
  "Database": {
    "UseInMemoryDatabase": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=GalleryBetakDb_Dev;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "SecretKey": "DevOnlySecretKey_MustBeAtLeast32Characters!"
  },
  "ProductImporter": {
    "RequestTimeoutSeconds": 20,
    "DelayBetweenRequestsMs": 600,
    "MaxImages": 4,
    "MaxImageSizeMb": 8,
    "RespectRobotsTxt": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}